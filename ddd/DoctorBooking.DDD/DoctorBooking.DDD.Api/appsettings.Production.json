{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "DoctorBooking": "Information"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "https://yourdomain.com",
      "https://app.yourdomain.com"
    ]
  },
  "RateLimiting": {
    "Fixed": {
      "PermitLimit": 1000,
      "WindowMinutes": 1,
      "QueueLimit": 10
    }
  }
}
