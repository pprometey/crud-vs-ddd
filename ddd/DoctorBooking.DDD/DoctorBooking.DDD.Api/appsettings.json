{
  "PersistenceStrategy": "Direct",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=doctorbooking.db",
    "MappedConnection": "Data Source=doctorbooking_mapped.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "Fixed": {
      "PermitLimit": 100,
      "WindowMinutes": 1,
      "QueueLimit": 0
    }
  }
}
